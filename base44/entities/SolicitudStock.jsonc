{
  "name": "SolicitudStock",
  "type": "object",
  "properties": {
    "equipo_id": {
      "type": "string"
    },
    "tipo_solicitud": {
      "type": "string",
      "enum": [
        "parches_adulto",
        "parches_nino",
        "parches_mixto",
        "bateria",
        "mantenimiento"
      ],
      "description": "Tipo de solicitud"
    },
    "cantidad": {
      "type": "number"
    },
    "descripcion": {
      "type": "string"
    },
    "estado": {
      "type": "string",
      "enum": [
        "pendiente",
        "aprobada",
        "rechazada",
        "completada"
      ],
      "default": "pendiente"
    },
    "solicitante_email": {
      "type": "string"
    },
    "fecha_solicitud": {
      "type": "string",
      "format": "date"
    },
    "respuesta_admin": {
      "type": "string"
    }
  },
  "required": [
    "equipo_id",
    "tipo_solicitud",
    "descripcion"
  ],
  "rls": {
    "create": true,
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "encargado_salud"
          }
        },
        {
          "user_condition": {
            "role": "encargado_compras_salud"
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "encargado_salud"
          }
        },
        {
          "user_condition": {
            "role": "encargado_compras_salud"
          }
        },
        {
          "$and": [
            {
              "created_by": "{{user.email}}"
            },
            {
              "data.estado": "pendiente"
            }
          ]
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "created_by": "{{user.email}}"
            },
            {
              "data.estado": "pendiente"
            }
          ]
        }
      ]
    }
  }
}