{
  "name": "Parche",
  "type": "object",
  "properties": {
    "equipo_id": {
      "type": "string",
      "description": "ID del equipo asociado"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "adulto",
        "pediatrico",
        "mixto"
      ],
      "description": "Categor\u00eda del parche"
    },
    "cantidad": {
      "type": "number"
    },
    "fecha_adquisicion": {
      "type": "string",
      "format": "date"
    },
    "fecha_vencimiento": {
      "type": "string",
      "format": "date"
    },
    "lote": {
      "type": "string"
    },
    "activo": {
      "type": "boolean",
      "default": true
    },
    "notas": {
      "type": "string"
    }
  },
  "required": [
    "equipo_id",
    "tipo",
    "cantidad",
    "fecha_vencimiento"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "user_condition": {
                "role": "encargado_salud"
              }
            },
            {
              "data.centro_principal": "{{user.centro_principal}}"
            }
          ]
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "user_condition": {
                "role": "encargado_salud"
              }
            },
            {
              "data.centro_principal": "{{user.centro_principal}}"
            }
          ]
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "$and": [
            {
              "user_condition": {
                "role": "encargado_salud"
              }
            },
            {
              "data.centro_principal": "{{user.centro_principal}}"
            }
          ]
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "super_admin"
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}